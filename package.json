{
  "name": "linxicon-solver",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "start:ps": "powershell -NoProfile -ExecutionPolicy Bypass -File server.ps1",
    "extract": "node scripts/extract-words.mjs",
    "build-graph": "node scripts/build-graph.mjs",
    "build-graph:resume": "node scripts/build-graph.mjs --resume",
    "build-graph:fast": "node scripts/build-graph.mjs --parallel 10 --chunk-parallel 4 --chunk 2000",
    "build-data": "powershell -ExecutionPolicy Bypass -File scripts/build-data.ps1"
  },
  "engines": {
    "node": ">=18"
  }
}
